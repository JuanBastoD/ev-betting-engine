# Async SQLAlchemy connection string. The driver in the URL is what picks the
# backend - no code changes needed to switch, only this value.
# Local dev/tests (aiosqlite):
DATABASE_URL=sqlite+aiosqlite:///./ev_betting.db
# Production (asyncpg):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ev_betting

# API key for the odds data provider (The Odds API).
ODDS_API_KEY=your_odds_api_key_here

# Base URL for The Odds API. Override only for a self-hosted proxy/mocking
# gateway - the default points at the real v4 API.
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# API token for Sportmonks (player-level stats, injuries, lineups).
SPORTMONKS_API_TOKEN=your_sportmonks_api_token_here

# Base URL for the Sportmonks Football API v3.
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football

# Fraction of full Kelly stake to use when sizing bets (0.0-1.0). 0.5 = half-Kelly.
KELLY_FRACTION=0.5

# Minimum edge (as a decimal fraction, e.g. 0.02 = 2%) required to flag a value bet.
MIN_EV_THRESHOLD=0.02

# Reference sharp bookmaker used to derive fair odds/probabilities.
SHARP_BOOKMAKER=Pinnacle
