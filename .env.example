# Async SQLAlchemy connection string. The driver in the URL is what picks the
# backend - no code changes needed to switch, only this value.
# Local dev/tests (aiosqlite):
DATABASE_URL=sqlite+aiosqlite:///./ev_betting.db
# Production (asyncpg):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ev_betting

# API key for the odds data provider (The Odds API).
ODDS_API_KEY=your_odds_api_key_here

# Base URL for The Odds API. Override only for a self-hosted proxy/mocking
# gateway - the default points at the real v4 API.
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# API token for Sportmonks (player-level stats, injuries, lineups).
SPORTMONKS_API_TOKEN=your_sportmonks_api_token_here

# Base URL for the Sportmonks Football API v3.
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football

# Fraction of full Kelly stake to use when sizing bets (0.0-1.0). 0.5 = half-Kelly.
KELLY_FRACTION=0.5

# Minimum edge (as a decimal fraction, e.g. 0.02 = 2%) required to flag a value bet.
MIN_EV_THRESHOLD=0.02

# Reference sharp bookmaker used to derive fair odds/probabilities.
SHARP_BOOKMAKER=Pinnacle

# The Odds API sport key for the league being tracked (one instance tracks one).
SPORT_KEY=soccer_epl

# Local bookmaker to scrape (must match a name registered with ScraperFactory:
# Betplay, Stake, or Betano).
LOCAL_BOOKMAKER=Betplay

# Average goals scored per team per match across the tracked league - used to
# normalize team attack/defense ratings in the match-statistics model.
LEAGUE_AVERAGE_GOALS=1.35

# Match-model double-confirmation policy: CONFIRMATION (market and statistical
# model must both agree) or INDEPENDENT (statistical model alone decides).
MATCH_CONFIRMATION_MODE=CONFIRMATION

# Weight on the market-derived probability when blending it with the
# statistical model's own, in CONFIRMATION mode (0.0-1.0).
MARKET_WEIGHT=0.5

# How often (in seconds) the scheduler runs the full ingest+detect pipeline.
PIPELINE_INTERVAL_SECONDS=3600

# Width of each calibration-curve bucket (0.1 = 10 buckets across [0,1]).
CALIBRATION_BUCKET_WIDTH=0.1

# Minimum settled bets a segment needs before CorrectionFactorService will
# compute a correction factor for it, rather than skip it as under-sampled.
CALIBRATION_MIN_SAMPLE_SIZE=30

# Comma-separated list of origins allowed to call this API from a browser
# (CORS). The frontend panel's Vite dev server runs on 5173 by default -
# if Vite picks a different port because 5173 is busy, add that origin
# here too.
CORS_ALLOWED_ORIGINS=http://localhost:5173
