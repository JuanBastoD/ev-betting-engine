# PostgreSQL connection string used by infrastructure repositories.
DATABASE_URL=postgresql://user:password@localhost:5432/ev_betting

# API key for the odds data provider.
ODDS_API_KEY=your_odds_api_key_here

# Fraction of full Kelly stake to use when sizing bets (0.0-1.0). 0.5 = half-Kelly.
KELLY_FRACTION=0.5

# Minimum edge (as a decimal fraction, e.g. 0.02 = 2%) required to flag a value bet.
MIN_EV_THRESHOLD=0.02

# Reference sharp bookmaker used to derive fair odds/probabilities.
SHARP_BOOKMAKER=Pinnacle
